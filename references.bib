% references.bib
%
% 参考文献数据库
% 使用方法: 在 .tex 正文中用 \cite{key} 引用,
% 编译时会自动按 GB/T 7714 格式生成文献列表.
%
% 常用类型: article (期刊), book (专著), inproceedings (会议),
%           phdthesis (博士论文), mastersthesis (硕士论文), misc (其他)

% ===== 示例文献 (请替换为自己的参考文献) =====

@article{example_article,
  author  = {张三 and 李四},
  title   = {一种改进的数值求解方法},
  journal = {应用数学学报},
  year    = {2024},
  volume  = {47},
  number  = {3},
  pages   = {401--415},
}

@book{example_book,
  author    = {王五},
  title     = {数学分析教程},
  publisher = {高等教育出版社},
  year      = {2022},
  address   = {北京},
  edition   = {3},
}

@inproceedings{example_conf,
  author    = {Doe, John and Smith, Jane},
  title     = {A Novel Approach to Optimization},
  booktitle = {Proceedings of the International Conference on Applied Mathematics},
  year      = {2023},
  pages     = {112--118},
  publisher = {Springer},
}

@phdthesis{example_thesis,
  author = {赵六},
  title  = {偏微分方程数值方法的稳定性分析},
  school = {吉林大学},
  year   = {2023},
}
